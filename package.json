{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "watch": "chokidar \"app/**/*.php\" \"routes/**/*.php\" \"config/**/*.php\" -c \"php artisan octane:reload --server=frankenphp\"",
        "dev:octane": "concurrently \"npm run dev\" \"npm run watch\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0",
        "chokidar-cli": "^3.0.0"
    }
}
